LINKEDIN_CLIENT_ID=REPLACE_ME
# Recommended for apps that do not have LinkedIn native PKCE enabled.
# If set, the MCP uses regular 3-legged OAuth instead of native PKCE.
# LINKEDIN_CLIENT_SECRET=REPLACE_ME
# LINKEDIN_OAUTH_FLOW=authorization_code
# LINKEDIN_REDIRECT_URI=http://127.0.0.1:63141/callback
LINKEDIN_SCOPES=r_dma_portability_3rd_party
LINKEDIN_API_VERSION=202312
LINKEDIN_RESTLI_PROTOCOL_VERSION=2.0.0
LINKEDIN_TIMEOUT_SECONDS=30
LINKEDIN_MAX_RETRIES=3
LINKEDIN_OAUTH_TIMEOUT_SECONDS=300
# Optional. Defaults to ~/.flin-linkedin-posts-mcp/tokens.json
# LINKEDIN_TOKEN_FILE=/absolute/path/to/tokens.json
RUN_LIVE_LINKEDIN_TESTS=0
